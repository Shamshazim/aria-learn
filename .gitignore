*.dump
*.sqlite
data/

# ── IDE / editor ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ─────────────────────────────────────────────────────
*.pid
.cache/
